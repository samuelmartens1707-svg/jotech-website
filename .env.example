LEXOFFICE_API_KEY=
LEXOFFICE_API_BASE_URL=https://api.lexware.io/v1
LEXOFFICE_AUTO_FINALIZE=false

# SMTP für den "Passwort vergessen"-Versand im Admin-Bereich.
# Solange SMTP_HOST leer ist, ist die Funktion inaktiv (kein Fehler, E-Mail wird nur nicht verschickt).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=JOTECH
SMTP_ENCRYPTION=tls
SMTP_ALLOW_SELF_SIGNED=false
